# =====================================
# clip
# =====================================
def clip(val, max_val):
    return max(
        min(val, max_val),
        -max_val
    )

# =====================================
# Segmentation PID 제어 함수
# =====================================
def reset_segmentation_pid():
    """Segmentation 제어 모드가 끝나거나 다시 시작할 때 PID 누적값 초기화."""

    global prev_steering
    global pid_integral
    global pid_prev_error
    global pid_prev_time
    global pid_filtered_derivative
    global pid_active_mode

    prev_steering = 0.0
    pid_integral = 0.0
    pid_prev_error = 0.0
    pid_prev_time = None
    pid_filtered_derivative = 0.0
    pid_active_mode = None


def calculate_segmentation_pid(error_norm, params, now, current_mode):
    """
    Segmentation mask 중심 오차(error_norm)를 이용한 PID steering 계산.

    P: 현재 차선 중심 오차에 반응
    I: 작은 편향이 계속 남아 있을 때 보정
    D: 오차가 급격히 바뀌는 경우 조향 변화를 완화

    추가로 smoothing과 steering step limit를 적용하여
    한 프레임에서 바퀴 명령이 크게 튀지 않도록 한다.
    """

    global prev_steering
    global pid_integral
    global pid_prev_error
    global pid_prev_time
    global pid_filtered_derivative
    global pid_active_mode

    # NORMAL_LEFT <-> NORMAL_RIGHT 전환 또는 PID 최초 진입 시 초기화
    if pid_active_mode != current_mode or pid_prev_time is None:
        pid_active_mode = current_mode
        pid_integral = 0.0
        pid_prev_error = error_norm
        pid_prev_time = now
        pid_filtered_derivative = 0.0

        p_term = params["Kp"] * error_norm
        i_term = 0.0
        d_term = 0.0

    else:
        # YOLO 추론 속도에 따라 dt가 튀어도 PID가 과민 반응하지 않도록 범위 제한
        dt = now - pid_prev_time
        dt = max(min(dt, 0.20), 0.02)

        pid_integral += error_norm * dt
        pid_integral = clip(
            pid_integral,
            PID_INTEGRAL_LIMIT
        )

        derivative = (
            (error_norm - pid_prev_error)
            / dt
        )

        pid_filtered_derivative = (
            PID_DERIVATIVE_FILTER * pid_filtered_derivative
            + (1 - PID_DERIVATIVE_FILTER) * derivative
        )

        p_term = params["Kp"] * error_norm
        i_term = params["Ki"] * pid_integral
        d_term = params["Kd"] * pid_filtered_derivative

        pid_prev_error = error_norm
        pid_prev_time = now

    raw_steering = (
        p_term
        + i_term
        + d_term
        + params["bias"]
    )

    # 기존 smoothing보다 더 부드럽게 적용
    smoothed_steering = (
        STEERING_SMOOTHING * prev_steering
        + (1 - STEERING_SMOOTHING) * raw_steering
    )

    # 한 프레임에서 조향값이 갑자기 커지는 것 제한
    steering_delta = smoothed_steering - prev_steering
    steering_delta = clip(
        steering_delta,
        MAX_STEERING_STEP
    )

    steering = prev_steering + steering_delta
    steering = clip(steering, SEG_MAX_STEER)

    prev_steering = steering

    return steering, p_term, i_term, d_term

# =====================================
# 차량 제어
# =====================================
def update_vehicle_motion(
    steering,
    speed,
    turn_strength,
    L_offset,
    R_offset
):
    steering = clip(
        steering,
        MAX_STEER
    )

    L = speed - steering * turn_strength
    R = speed + steering * turn_strength

    L += L_offset
    R += R_offset

    L = clip(L, MAX_SPEED)
    R = clip(R, MAX_SPEED)

    send_control_async(R, L)

    print(
        f"[AUTO] "
        f"Mode: {drive_mode:<35} "
        f"Steer: {steering:+.2f} "
        f"L: {L:+.2f} "
        f"R: {R:+.2f}"
    )

