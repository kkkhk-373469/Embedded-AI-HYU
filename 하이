        num_classes=2
    )
    return model

# =====================================
# 모델 로드
# =====================================
def load_model(weight_path):
    model = get_model()
    model.load_state_dict(
        torch.load(
            weight_path,
            map_location=device
        )
    )
    model = model.to(device)
    model.eval()
    print(f"[INFO] Loaded: {weight_path}")
    return model

